# Application
APP_NAME=ct200-manual-api
APP_ENV=development

# SQLite (relative path is resolved from the project root)
DATABASE_URL=sqlite:///./ct200.db

# MongoDB — LLM generation payload storage
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=ct200_generations

# Gemini — required for QA generation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
LLM_MAX_RETRIES=2
